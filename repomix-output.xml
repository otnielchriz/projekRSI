import { Button } from "./ui/button";

export default function AdminNavbar() {
  const navigate = useNavigate();
  const [me, setMe] = useState<UserMe | null>(null);

  useEffect(() => {
    authApi.me().then(setMe).catch(() => {
      clearAuth();
      navigate("/login");
